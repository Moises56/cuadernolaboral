# ══════════════════════════════════════════════
# CuadernoLaboral — Variables de entorno
# Copia este archivo a .env.local y completa los valores
# ══════════════════════════════════════════════

# ── Base de datos (Neon PostgreSQL) ──────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST/cuadernolaboral?sslmode=require"

# ── Cloudinary ───────────────────────────────
CLOUDINARY_CLOUD_NAME="tu_cloud_name"
CLOUDINARY_API_KEY="tu_api_key"
CLOUDINARY_API_SECRET="tu_api_secret"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="tu_cloud_name"

# ── App ──────────────────────────────────────
# URL de producción (sin trailing slash)
NEXT_PUBLIC_APP_URL="https://cuadernolaboral.vercel.app"

# ── Cookie de sesión ─────────────────────────
# Generar con: openssl rand -base64 32
SESSION_SECRET="cambiar_por_valor_aleatorio_seguro"
